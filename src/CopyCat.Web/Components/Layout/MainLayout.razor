@inherits LayoutComponentBase

<MudThemeProvider/>
<MudDialogProvider/>
<MudSnackbarProvider/>
<MudPopoverProvider/>

<MudLayout>
    <MudAppBar Elevation="1" Dense="true">
        <MudText Typo="Typo.h6">CopyCat</MudText>
        <MudSpacer/>
        <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined">Private Admin</MudChip>
    </MudAppBar>
    <MudDrawer Open="true" Variant="DrawerVariant.Mini" Elevation="1">
        <MudNavMenu>
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
            <MudNavLink Href="/sessions" Icon="@Icons.Material.Filled.Badge">Sessions</MudNavLink>
            <MudNavLink Href="/channels" Icon="@Icons.Material.Filled.Forum">Channels</MudNavLink>
            <MudNavLink Href="/mappings" Icon="@Icons.Material.Filled.AltRoute">Mappings</MudNavLink>
            <MudNavLink Href="/history" Icon="@Icons.Material.Filled.History">History</MudNavLink>
            <MudNavLink Href="/forwarding-jobs" Icon="@Icons.Material.Filled.Sync">Jobs</MudNavLink>
            <MudNavLink Href="/audit-log" Icon="@Icons.Material.Filled.FactCheck">Audit</MudNavLink>
            <MudNavLink Href="/settings" Icon="@Icons.Material.Filled.Settings">Settings</MudNavLink>
        </MudNavMenu>
    </MudDrawer>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.False" Class="pa-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>An unhandled error has occurred. <a href=".">Reload</a></div>

